# ─── Supabase (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service-role key — never expose to the browser; used only in Edge Functions
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── AI / Anthropic (required for AI Assist feature) ─────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── CORS (required in production for Edge Functions) ────────────────────────
# Set this to your deployed app URL, e.g. https://your-app.vercel.app
ALLOWED_ORIGIN=http://localhost:3000

# ─── Institution onboarding (PR A) ───────────────────────────────────────────
# Email that receives institution inquiry notifications from /contact-institutions.
INSTITUTION_INQUIRY_NOTIFY_EMAIL=plexus.science@outlook.de
# Comma-separated auth.users UUIDs allowed to access /admin/institutions.
# Find yours with: select id from auth.users where email = 'your@email';
PLATFORM_ADMIN_USER_IDS=
