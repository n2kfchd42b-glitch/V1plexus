# ─── Supabase (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service-role key — never expose to the browser; used only in Edge Functions
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── AI / Anthropic (required for AI Assist feature) ─────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Analytics service (REQUIRED in production) ──────────────────────────────
# Base URL of the external PLEXUS Analytics (FastAPI) service that powers
# narratives, causal estimation, sensitivity analysis, data portraits and
# research-output packaging. If this is unset in production the app fails loud
# (see src/lib/analyticsService.ts) rather than silently pointing at localhost.
# In local dev it defaults to http://localhost:8000 when omitted.
ANALYTICS_API_URL=http://localhost:8000

# ─── Rate limiting (optional; durable across serverless instances) ───────────
# When both are set, API rate limits use Upstash Redis (shared across all
# instances). When unset, limits fall back to a best-effort per-instance
# in-memory counter. Provision a free Redis at https://upstash.com.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cron (required for scheduled deadline sweeps) ───────────────────────────
# Shared secret that authenticates Vercel Cron requests to /api/cron/*.
# Vercel sets the Authorization header from this value automatically.
# Generate one with: openssl rand -hex 32
CRON_SECRET=your_cron_secret

# ─── Transactional email (required for invites & notifications) ──────────────
# Resend API key used to send invitation and notification emails.
RESEND_API_KEY=your_resend_api_key

# ─── App URL (used in email links and absolute redirects) ────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── CORS (required in production for Edge Functions) ────────────────────────
# Set this to your deployed app URL, e.g. https://your-app.vercel.app
ALLOWED_ORIGIN=http://localhost:3000

# ─── Institution onboarding (PR A) ───────────────────────────────────────────
# Email that receives institution inquiry notifications from /contact-institutions.
INSTITUTION_INQUIRY_NOTIFY_EMAIL=plexus.science@outlook.de
# Comma-separated auth.users UUIDs allowed to access /admin/institutions.
# Find yours with: select id from auth.users where email = 'your@email';
PLATFORM_ADMIN_USER_IDS=
